# 服务器配置
PORT=3001
NODE_ENV=development

# ==================== 数据库配置 ====================
# 选择以下两种方式之一配置数据库

# 方式 1：云数据库（推荐，如 Supabase）
# 从 Supabase → Settings → Database → Connection string 复制 URI
DATABASE_URL=postgres://postgres.xxxxxxxxxxxxx:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# 方式 2：本地 PostgreSQL
# 取消以下注释并注释掉 DATABASE_URL
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=smart_fitness
# DB_USER=postgres
# DB_PASSWORD=your_password

# ==================== JWT 密钥 ====================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

# ==================== 前端地址（CORS）====================
CLIENT_URL=http://localhost:5173